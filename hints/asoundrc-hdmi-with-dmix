# mixed PCM setup: sound output can be shared by software mixing

pcm.!default {
    type plug
    slave.pcm "dmixed"
}

pcm.dmixed {
    type dmix
    ipc_key 1024

    slave {
        pcm "hw:0,3"
        channels 2
    }
}

